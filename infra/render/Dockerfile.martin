# Martin tile server for Render (Phase 1 basemap).
#
# Render can't run docker-compose, so this is a single self-contained image:
#   - the Martin binary (fetched from the official GitHub release, pinned)
#   - the self-hosted fonts + sprites (baked from the repo)
#   - an entrypoint that downloads vietnam.pmtiles from $PMTILES_URL on first
#     boot, then serves tiles/fonts/sprites under /tiles/*
#
# The heavy terrain overlays (hillshade/contours/terrain .mbtiles) are omitted
# on purpose — they don't exist yet and would make Martin crash-loop.
#
# Build context must be the REPO ROOT (render.yaml sets dockerContext: .).

FROM debian:bookworm-slim

# Pin the Martin version so builds are reproducible.
ARG MARTIN_VERSION=martin-v1.10.1
ARG MARTIN_ASSET=martin-x86_64-unknown-linux-musl.tar.gz

# curl + CA certs: needed both to fetch Martin here and to download the
# basemap at runtime (entrypoint).
RUN apt-get update \
 && apt-get install -y --no-install-recommends curl ca-certificates \
 && rm -rf /var/lib/apt/lists/*

# Fetch the statically-linked Martin binary and install it.
RUN curl -fSL "https://github.com/maplibre/martin/releases/download/${MARTIN_VERSION}/${MARTIN_ASSET}" -o /tmp/martin.tar.gz \
 && tar -xzf /tmp/martin.tar.gz -C /tmp \
 && bin="$(find /tmp -maxdepth 2 -type f -name martin | head -1)" \
 && test -n "$bin" \
 && mv "$bin" /usr/local/bin/martin \
 && chmod +x /usr/local/bin/martin \
 && rm -rf /tmp/martin.tar.gz \
 && martin --version

# Self-hosted glyphs + sprites (already in the repo).
COPY services/tiles/fonts /fonts
COPY services/tiles/sprites /sprites

COPY infra/render/martin-entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh

# Where the downloaded basemap lands. Mount a Render disk here to persist it
# across restarts (optional; see render.yaml).
ENV PMTILES_PATH=/data/vietnam.pmtiles

# Render provides $PORT; Martin binds to it (falls back to 3000 locally).
EXPOSE 3000
ENTRYPOINT ["/entrypoint.sh"]
